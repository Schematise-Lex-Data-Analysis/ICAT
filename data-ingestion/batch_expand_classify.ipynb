    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Batch Expansion & Azure Classification\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook reads all `classified_index` + `stored_results` data from the source DB,\\n\",\n",
    "    \"expands every matched snippet to its full surrounding clause **and** classifies it in a\\n\",\n",
    "    \"single LLM call (the LLM decides clause boundaries instead of regex), then writes\\n\",\n",
    "    \"everything into a new database named `icat-v2-beta`.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Uses DB-backed streaming for checkpoint/resume: a server-side cursor streams source rows,\\n\",\n",
    "    \"and a batch existence check against the target DB skips already-processed rows.\\n\",\n",
    "    \"No in-memory `processed_ids` set or `work_queue` list.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 1,\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-18T09:01:05.758025700Z\",\n",
    "     \"start_time\": \"2026-03-18T09:01:05.469147100Z\"\n",
    "    }\n",
    "   },\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Configuration loaded.\\n\",\n",
    "      \"  Working directory: /home/sankalp-user/Development/ICAT-SLDA/data-ingestion\\n\",\n",
    "      \"  BATCH_SIZE = 10\\n\",\n",
    "      \"  TARGET_DB_NAME = icat-v2-beta\\n\",\n",
    "      \"  STATS_FILE = stats_v2_beta.json\\n\",\n",
    "      \"  MODEL_NAME = Llama-3.3-70B-Instruct\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"# Cell 1: Imports & Configuration\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"from datetime import datetime\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Jupyter sets cwd to the notebook's directory on launch.\\n\",\n",
    "    \"# If it's not already data-ingestion/, correct it now.\\n\",\n",
    "    \"if os.path.basename(os.getcwd()) != \\\"data-ingestion\\\":\\n\",\n",
    "    \"    os.chdir(os.path.join(os.getcwd(), \\\"data-ingestion\\\"))\\n\",\n",
    "    \"_nb_dir = os.getcwd()\\n\",\n",
    "    \"if _nb_dir not in sys.path:\\n\",\n",
    "    \"    sys.path.insert(0, _nb_dir)\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import psycopg\\n\",\n",
    "    \"from dotenv import load_dotenv\\n\",\n",
    "    \"\\n\",\n",
    "    \"load_dotenv()\\n\",\n",
    "    \"\\n\",\n",
    "    \"import insert_data\\n\",\n",
    "    \"import pipelineoperation\\n\",\n",
    "    \"\\n\",\n",
    "    \"STATS_FILE = \\\"stats_v2_beta.json\\\"\\n\",\n",
    "    \"BATCH_SIZE = 10\\n\",\n",
    "    \"TARGET_DB_NAME = \\\"icat-v2-beta\\\"\\n\",\n",
    "    \"AZURE_INFERENCE_MODEL = os.environ.get(\\\"AZURE_INFERENCE_MODEL\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Configuration loaded.\\\")\\n\",\n",
    "    \"print(f\\\"  Working directory: {os.getcwd()}\\\")\\n\",\n",
    "    \"print(f\\\"  BATCH_SIZE = {BATCH_SIZE}\\\")\\n\",\n",
    "    \"print(f\\\"  TARGET_DB_NAME = {TARGET_DB_NAME}\\\")\\n\",\n",
    "    \"print(f\\\"  STATS_FILE = {STATS_FILE}\\\")\\n\",\n",
    "    \"print(f\\\"  MODEL_NAME = {AZURE_INFERENCE_MODEL}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 2,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Connected to source DB: icatv1\\n\",\n",
    "      \"Database 'icat-v2-beta' already exists\\n\",\n",
    "      \"Connected to target DB: icat-v2-beta\\n\",\n",
    "      \"Database initialized\\n\",\n",
    "      \"Target DB schema initialized.\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"# Cell 2: Database Connections\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Source connection (uses env vars as-is)\\n\",\n",
    "    \"source_conn = insert_data.create_connection()\\n\",\n",
    "    \"assert source_conn is not None, \\\"Failed to connect to source database\\\"\\n\",\n",
    "    \"print(f\\\"Connected to source DB: {os.environ.get('DB_NAME')}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create target database if it doesn't exist\\n\",\n",
    "    \"admin_uri = (\\n\",\n",
    "    \"    f\\\"host={insert_data.DB_HOST} dbname={insert_data.DB_NAME} \\\"\\n\",\n",
    "    \"    f\\\"user={insert_data.DB_USER} password={insert_data.DB_PASS} \\\"\\n\",\n",
    "    \"    f\\\"sslmode={insert_data.DB_SSLMODE}\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"admin_conn = psycopg.connect(admin_uri, autocommit=True)\\n\",\n",
    "    \"with admin_conn.cursor() as cur:\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        cur.execute(f'CREATE DATABASE \\\"{TARGET_DB_NAME}\\\"')\\n\",\n",
    "    \"        print(f\\\"Created database '{TARGET_DB_NAME}'\\\")\\n\",\n",
    "    \"    except psycopg.errors.DuplicateDatabase:\\n\",\n",
    "    \"        print(f\\\"Database '{TARGET_DB_NAME}' already exists\\\")\\n\",\n",
    "    \"admin_conn.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Connect to target database\\n\",\n",
    "    \"target_uri = (\\n\",\n",
    "    \"    f\\\"host={insert_data.DB_HOST} dbname={TARGET_DB_NAME} \\\"\\n\",\n",
    "    \"    f\\\"user={insert_data.DB_USER} password={insert_data.DB_PASS} \\\"\\n\",\n",
    "    \"    f\\\"sslmode={insert_data.DB_SSLMODE}\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"target_conn = psycopg.connect(target_uri)\\n\",\n",
    "    \"print(f\\\"Connected to target DB: {TARGET_DB_NAME}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Initialize schema in target\\n\",\n",
    "    \"insert_data.initialize_db(target_conn)\\n\",\n",
    "    \"print(\\\"Target DB schema initialized.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 3,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"RLIMIT_AS cleared (was set by a previous run)\\n\",\n",
    "      \"[MEM baseline after cell 2b] RSS: 141 MB  VmSize: 1407 MB  peak: 209 MB\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"# Cell 2b: Memory diagnostics\\n\",\n",
    "    \"import resource\\n\",\n",
    "    \"\\n\",\n",
    "    \"def mem_report(label=\\\"\\\"):\\n\",\n",
    "    \"    \\\"\\\"\\\"Print current RSS, virtual size, and peak RSS.\\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        with open('/proc/self/status') as f:\\n\",\n",
    "    \"            rss_mb = vm_mb = 0\\n\",\n",
    "    \"            for line in f:\\n\",\n",
    "    \"                if line.startswith('VmRSS:'):\\n\",\n",
    "    \"                    rss_mb = int(line.split()[1]) / 1024\\n\",\n",
    "    \"                elif line.startswith('VmSize:'):\\n\",\n",
    "    \"                    vm_mb = int(line.split()[1]) / 1024\\n\",\n",
    "    \"    except OSError:\\n\",\n",
    "    \"        rss_mb = vm_mb = 0\\n\",\n",
    "    \"    peak_mb = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss / 1024\\n\",\n",
    "    \"    print(f\\\"[MEM {label}] RSS: {rss_mb:.0f} MB  VmSize: {vm_mb:.0f} MB  peak: {peak_mb:.0f} MB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Remove any RLIMIT_AS set by previous cell runs (persists across cell re-executions).\\n\",\n",
    "    \"# RLIMIT_AS caps virtual address space, NOT physical RAM — the openai/httpx/SSL stack\\n\",\n",
    "    \"# uses ~7-8 GB of virtual mappings while only consuming ~150 MB of real memory.\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    resource.setrlimit(resource.RLIMIT_AS, (resource.RLIM_INFINITY, resource.RLIM_INFINITY))\\n\",\n",
    "    \"    print(\\\"RLIMIT_AS cleared (was set by a previous run)\\\")\\n\",\n",
    "    \"except (ValueError, resource.error) as e:\\n\",\n",
    "    \"    print(f\\\"Could not clear RLIMIT_AS: {e}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"mem_report(\\\"baseline after cell 2b\\\")\"\n",
    "   ]\n",
    "  },\n",
