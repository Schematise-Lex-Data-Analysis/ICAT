    "    \"\\n\",\n",
    "    \"# Close connections\\n\",\n",
    "    \"source_conn.close()\\n\",\n",
    "    \"target_conn.close()\\n\",\n",
    "    \"print(\\\"\\\\nBoth database connections closed.\\\")\"\n",
    "   ]\n",
    "  }\n",
