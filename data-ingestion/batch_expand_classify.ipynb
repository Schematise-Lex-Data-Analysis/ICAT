    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 4: Copy Base Tables to Target\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Clear any aborted transaction state, reload module, ensure tables exist\\n\",\n",
    "    \"target_conn.rollback()\\n\",\n",
    "    \"import importlib\\n\",\n",
    "    \"importlib.reload(insert_data)\\n\",\n",
    "    \"insert_data.initialize_db(target_conn)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copy stored_results using a server-side cursor to avoid loading all rows into RAM\\n\",\n",
    "    \"inserted_sr = 0\\n\",\n",
    "    \"total_sr = 0\\n\",\n",
    "    \"with source_conn.cursor(name=\\\"copy_stored_results\\\") as src_cur:\\n\",\n",
    "    \"    src_cur.itersize = 100\\n\",\n",
    "    \"    src_cur.execute(\\\"SELECT Doc_ID, Title, Doc_Text, Doc_Blockquotes, Doc_Size FROM stored_results\\\")\\n\",\n",
    "    \"    batch = []\\n\",\n",
    "    \"    for row in src_cur:\\n\",\n",
    "    \"        total_sr += 1\\n\",\n",
    "    \"        batch.append(row)\\n\",\n",
    "    \"        if len(batch) >= 100:\\n\",\n",
    "    \"            with target_conn.cursor() as tgt_cur:\\n\",\n",
    "    \"                for r in batch:\\n\",\n",
    "    \"                    tgt_cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                        INSERT INTO stored_results (Doc_ID, Title, Doc_Text, Doc_Blockquotes, Doc_Size)\\n\",\n",
    "    \"                        VALUES (%s, %s, %s, %s, %s)\\n\",\n",
    "    \"                        ON CONFLICT (Doc_ID) DO NOTHING\\n\",\n",
    "    \"                    \\\"\\\"\\\", r)\\n\",\n",
    "    \"                    inserted_sr += tgt_cur.rowcount\\n\",\n",
    "    \"            target_conn.commit()\\n\",\n",
    "    \"            batch = []\\n\",\n",
    "    \"    # Final partial batch\\n\",\n",
    "    \"    if batch:\\n\",\n",
    "    \"        with target_conn.cursor() as tgt_cur:\\n\",\n",
    "    \"            for r in batch:\\n\",\n",
    "    \"                tgt_cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                    INSERT INTO stored_results (Doc_ID, Title, Doc_Text, Doc_Blockquotes, Doc_Size)\\n\",\n",
    "    \"                    VALUES (%s, %s, %s, %s, %s)\\n\",\n",
    "    \"                    ON CONFLICT (Doc_ID) DO NOTHING\\n\",\n",
    "    \"                \\\"\\\"\\\", r)\\n\",\n",
    "    \"                inserted_sr += tgt_cur.rowcount\\n\",\n",
    "    \"        target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"stored_results: {total_sr} source rows, {inserted_sr} newly inserted into target\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Copy search_queries\\n\",\n",
    "    \"with source_conn.cursor() as src_cur:\\n\",\n",
    "    \"    src_cur.execute(\\\"SELECT searchquery, dateandtime FROM search_queries\\\")\\n\",\n",
    "    \"    sq_rows = src_cur.fetchall()\\n\",\n",
    "    \"\\n\",\n",
    "    \"with target_conn.cursor() as tgt_cur:\\n\",\n",
    "    \"    for row in sq_rows:\\n\",\n",
    "    \"        tgt_cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"            INSERT INTO search_queries (searchquery, dateandtime)\\n\",\n",
    "    \"            VALUES (%s, %s)\\n\",\n",
    "    \"        \\\"\\\"\\\", row)\\n\",\n",
    "    \"    target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"search_queries: {len(sq_rows)} rows copied to target\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 5: Extract Court Metadata for stored_results\\n\",\n",
    "    \"# Populates court_name, judgment_date, case_citation using Indian Kanoon API + LLM fallback.\\n\",\n",
    "    \"# Has its own checkpoint file so it can be re-run independently.\\n\",\n",
    "    \"\\n\",\n",
    "    \"import importlib\\n\",\n",
    "    \"importlib.reload(pipelineoperation)\\n\",\n",
    "    \"importlib.reload(insert_data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"from app import fetch_docmeta\\n\",\n",
    "    \"from pipelineoperation import extract_metadata_with_azure\\n\",\n",
    "    \"\\n\",\n",
    "    \"METADATA_CHECKPOINT = \\\"checkpoint_metadata.json\\\"\\n\",\n",
    "    \"api_key = os.environ.get(\\\"API_KEY\\\")\\n\",\n",
    "    \"meta_headers = {'authorization': f\\\"Token {api_key}\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Load metadata checkpoint\\n\",\n",
    "    \"if os.path.exists(METADATA_CHECKPOINT):\\n\",\n",
    "    \"    with open(METADATA_CHECKPOINT, 'r') as f:\\n\",\n",
    "    \"        meta_ckpt = json.load(f)\\n\",\n",
    "    \"    meta_processed = set(meta_ckpt.get('processed_doc_ids', []))\\n\",\n",
    "    \"    print(f\\\"Metadata checkpoint loaded: {len(meta_processed)} docs already processed\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    meta_processed = set()\\n\",\n",
    "    \"    print(\\\"No metadata checkpoint found. Starting fresh.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Find docs needing metadata\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        SELECT Doc_ID, Doc_Text FROM stored_results\\n\",\n",
    "    \"        WHERE court_name IS NULL OR court_name = ''\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    docs_needing_meta = cur.fetchall()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Filter out already-checkpointed docs\\n\",\n",
    "    \"docs_to_process = [(d, t) for d, t in docs_needing_meta if d not in meta_processed]\\n\",\n",
    "    \"print(f\\\"{len(docs_to_process)} docs need metadata ({len(docs_needing_meta)} total without, {len(meta_processed)} already done)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"meta_stats = {'api_success': 0, 'llm_fallback': 0, 'failed': 0}\\n\",\n",
    "    \"\\n\",\n",
    "    \"for i, (doc_id, doc_text) in enumerate(docs_to_process):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # Try API first\\n\",\n",
    "    \"        meta = fetch_docmeta(doc_id, meta_headers)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # If court_name still empty, use LLM fallback\\n\",\n",
    "    \"        if not meta.get('court_name') and doc_text:\\n\",\n",
    "    \"            meta = extract_metadata_with_azure(doc_text[:2000])\\n\",\n",
    "    \"            meta_stats['llm_fallback'] += 1\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            meta_stats['api_success'] += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Update stored_results\\n\",\n",
    "    \"        with target_conn.cursor() as cur:\\n\",\n",
    "    \"            cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                UPDATE stored_results\\n\",\n",
    "    \"                SET court_name = %s, judgment_date = %s, case_citation = %s\\n\",\n",
    "    \"                WHERE Doc_ID = %s\\n\",\n",
    "    \"            \\\"\\\"\\\", (meta.get('court_name', ''), meta.get('judgment_date', ''),\\n\",\n",
    "    \"                  meta.get('case_citation', ''), doc_id))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        meta_processed.add(doc_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Checkpoint every BATCH_SIZE docs\\n\",\n",
    "    \"        if (i + 1) % BATCH_SIZE == 0:\\n\",\n",
    "    \"            target_conn.commit()\\n\",\n",
    "    \"            with open(METADATA_CHECKPOINT, 'w') as f:\\n\",\n",
    "    \"                json.dump({'processed_doc_ids': list(meta_processed),\\n\",\n",
    "    \"                           'last_updated': datetime.now().isoformat(),\\n\",\n",
    "    \"                           'stats': meta_stats}, f, indent=2)\\n\",\n",
    "    \"            print(f\\\"  Metadata: {i + 1}/{len(docs_to_process)} processed \\\"\\n\",\n",
    "    \"                  f\\\"(API: {meta_stats['api_success']}, LLM: {meta_stats['llm_fallback']})\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        time.sleep(0.2)  # rate limit\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"  Metadata error for {doc_id}: {e}\\\")\\n\",\n",
    "    \"        meta_stats['failed'] += 1\\n\",\n",
    "    \"        meta_processed.add(doc_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Final commit and checkpoint\\n\",\n",
    "    \"target_conn.commit()\\n\",\n",
    "    \"with open(METADATA_CHECKPOINT, 'w') as f:\\n\",\n",
    "    \"    json.dump({'processed_doc_ids': list(meta_processed),\\n\",\n",
    "    \"               'last_updated': datetime.now().isoformat(),\\n\",\n",
    "    \"               'stats': meta_stats}, f, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nMetadata extraction complete:\\\")\\n\",\n",
    "    \"print(f\\\"  API success: {meta_stats['api_success']}\\\")\\n\",\n",
    "    \"print(f\\\"  LLM fallback: {meta_stats['llm_fallback']}\\\")\\n\",\n",
    "    \"print(f\\\"  Failed: {meta_stats['failed']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 6: Load Stats\\n\",\n",
    "    \"\\n\",\n",
    "    \"if os.path.exists(STATS_FILE):\\n\",\n",
    "    \"    with open(STATS_FILE, 'r') as f:\\n\",\n",
    "    \"        stats = json.load(f)\\n\",\n",
    "    \"    print(f\\\"Stats loaded: {stats}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    stats = {\\n\",\n",
    "    \"        'total_processed': 0,\\n\",\n",
    "    \"        'total_expanded': 0,\\n\",\n",
    "    \"        'total_classified_as_clause': 0,\\n\",\n",
    "    \"        'total_discussions_extracted': 0,\\n\",\n",
    "    \"        'total_errors': 0,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    print(\\\"No stats file found. Starting fresh.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 7: Streaming Generator — replaces in-memory work_queue\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _filter_already_processed(target_conn, rows):\\n\",\n",
    "    \"    \\\"\\\"\\\"Filter out rows whose (doc_id, searchquery) already exist in the target classified_index.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Uses a VALUES join so the check is a single round-trip per batch.\\n\",\n",
    "    \"    Returns only unprocessed rows as dicts with raw (unparsed) snippet strings.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    if not rows:\\n\",\n",
    "    \"        return []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Build pairs for the VALUES clause\\n\",\n",
    "    \"    pairs = [(r[0], r[2]) for r in rows]  # (doc_id, searchquery)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Build the VALUES placeholders: (%s, %s), (%s, %s), ...\\n\",\n",
    "    \"    values_placeholder = \\\", \\\".join([\\\"(%s, %s)\\\"] * len(pairs))\\n\",\n",
    "    \"    query = f\\\"\\\"\\\"\\n\",\n",
    "    \"        SELECT v.doc_id, v.searchquery\\n\",\n",
    "    \"        FROM (VALUES {values_placeholder}) AS v(doc_id, searchquery)\\n\",\n",
    "    \"        INNER JOIN classified_index ci\\n\",\n",
    "    \"            ON ci.Doc_Id = v.doc_id AND ci.searchquery = v.searchquery\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    flat_params = [item for pair in pairs for item in pair]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with target_conn.cursor() as cur:\\n\",\n",
    "    \"        cur.execute(query, flat_params)\\n\",\n",
    "    \"        existing = set()\\n\",\n",
    "    \"        for row in cur:\\n\",\n",
    "    \"            existing.add((row[0], row[1]))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Return unprocessed rows as dicts — keep raw strings, don't parse into lists\\n\",\n",
    "    \"    result = []\\n\",\n",
    "    \"    for r in rows:\\n\",\n",
    "    \"        doc_id, title, searchquery, mi_raw, mc_raw, mc_after_raw, mi_after_raw = r\\n\",\n",
    "    \"        if (doc_id, searchquery) not in existing:\\n\",\n",
    "    \"            result.append({\\n\",\n",
    "    \"                'doc_id': doc_id,\\n\",\n",
    "    \"                'title': title,\\n\",\n",
    "    \"                'searchquery': searchquery,\\n\",\n",
    "    \"                'matching_indents_raw': mi_raw,\\n\",\n",
    "    \"                'matching_columns_raw': mc_raw,\\n\",\n",
    "    \"                'matching_columns_after_classification_raw': mc_after_raw,\\n\",\n",
    "    \"                'matching_indents_after_classification_raw': mi_after_raw,\\n\",\n",
    "    \"            })\\n\",\n",
    "    \"    return result\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def iter_unprocessed_batches(source_conn, target_conn, batch_size):\\n\",\n",
    "    \"    \\\"\\\"\\\"Generator that streams rows from source classified_index via a server-side cursor\\n\",\n",
    "    \"    and yields batches of unprocessed row dicts (filtered against target DB).\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    with source_conn.cursor(name=\\\"stream_classified_index\\\") as src_cur:\\n\",\n",
    "    \"        src_cur.itersize = batch_size\\n\",\n",
    "    \"        src_cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"            SELECT doc_id, title, searchquery, matching_indents, matching_columns,\\n\",\n",
    "    \"                   matching_columns_after_classification, matching_indents_after_classification\\n\",\n",
    "    \"            FROM classified_index\\n\",\n",
    "    \"        \\\"\\\"\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        batch = []\\n\",\n",
    "    \"        for row in src_cur:\\n\",\n",
    "    \"            batch.append(row)\\n\",\n",
    "    \"            if len(batch) >= batch_size:\\n\",\n",
    "    \"                unprocessed = _filter_already_processed(target_conn, batch)\\n\",\n",
    "    \"                batch = []\\n\",\n",
    "    \"                if unprocessed:\\n\",\n",
    "    \"                    yield unprocessed\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Final partial batch\\n\",\n",
    "    \"        if batch:\\n\",\n",
    "    \"            unprocessed = _filter_already_processed(target_conn, batch)\\n\",\n",
    "    \"            if unprocessed:\\n\",\n",
    "    \"                yield unprocessed\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display source and target counts (no full fetch)\\n\",\n",
    "    \"with source_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index\\\")\\n\",\n",
    "    \"    source_count = cur.fetchone()[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index\\\")\\n\",\n",
    "    \"    target_count = cur.fetchone()[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"remaining = source_count - target_count\\n\",\n",
    "    \"print(f\\\"Source classified_index rows: {source_count}\\\")\\n\",\n",
    "    \"print(f\\\"Target classified_index rows: {target_count} (already processed)\\\")\\n\",\n",
    "    \"print(f\\\"Approximate remaining: {remaining}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 8: Process — Expand, Classify & Extract Discussion (main loop)\\n\",\n",
    "    \"# Per snippet: one LLM call for expand + classify (with confidence scores).\\n\",\n",
    "    \"# Per row (if contract clauses found): one LLM call for discussion extraction.\\n\",\n",
    "    \"# Run Cell 6 (stats) and Cell 7 (streaming setup) before this cell.\\n\",\n",
    "    \"# Doc_Text never enters Python — all text ops are parameterised SQL inside the functions.\\n\",\n",
    "    \"# Snippet results go to a staging temp table; final INSERT is built via SQL aggregation.\\n\",\n",
    "    \"\\n\",\n",
    "    \"import importlib\\n\",\n",
    "    \"importlib.reload(pipelineoperation)\\n\",\n",
    "    \"from pipelineoperation import expand_and_classify_with_azure, extract_discussion_with_azure\\n\",\n",
    "    \"\\n\",\n",
    "    \"def save_stats():\\n\",\n",
    "    \"    \\\"\\\"\\\"Save current stats to stats file.\\\"\\\"\\\"\\n\",\n",
    "    \"    stats['last_updated'] = datetime.now().isoformat()\\n\",\n",
    "    \"    with open(STATS_FILE, 'w') as f:\\n\",\n",
    "    \"        json.dump(stats, f, indent=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def expand_classify_with_retry(conn, doc_id, snippet, max_retries=3):\\n\",\n",
    "    \"    \\\"\\\"\\\"Combined expand+classify with retry on transient failures.\\\"\\\"\\\"\\n\",\n",
    "    \"    for attempt in range(max_retries):\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            return expand_and_classify_with_azure(conn, doc_id, snippet)\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            if attempt < max_retries - 1:\\n\",\n",
    "    \"                wait = 2 ** attempt\\n\",\n",
    "    \"                print(f\\\"  Retry {attempt + 1}/{max_retries} after {wait}s: {e}\\\")\\n\",\n",
    "    \"                time.sleep(wait)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                raise\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def extract_discussion_with_retry(conn, doc_id, clause, max_retries=3):\\n\",\n",
    "    \"    \\\"\\\"\\\"Extract discussion with retry on transient failures.\\\"\\\"\\\"\\n\",\n",
    "    \"    for attempt in range(max_retries):\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            return extract_discussion_with_azure(conn, doc_id, clause)\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            if attempt < max_retries - 1:\\n\",\n",
    "    \"                wait = 2 ** attempt\\n\",\n",
    "    \"                print(f\\\"  Discussion retry {attempt + 1}/{max_retries} after {wait}s: {e}\\\")\\n\",\n",
    "    \"                time.sleep(wait)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                raise\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Create staging temp table for per-snippet results (recreated each run)\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"DROP TABLE IF EXISTS _staging_snippets\\\")\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        CREATE TEMP TABLE _staging_snippets (\\n\",\n",
    "    \"            doc_id TEXT, searchquery TEXT,\\n\",\n",
    "    \"            snippet_type TEXT, snippet_text TEXT, clause_text TEXT,\\n\",\n",
    "    \"            is_contract_clause BOOLEAN, confidence FLOAT, reasoning TEXT\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Starting processing (streaming from source, BATCH_SIZE={BATCH_SIZE})\\\")\\n\",\n",
    "    \"batch_num = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"for batch in iter_unprocessed_batches(source_conn, target_conn, BATCH_SIZE):\\n\",\n",
    "    \"    batch_num += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for row in batch:\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            # Clear staging for this row\\n\",\n",
    "    \"            with target_conn.cursor() as cur:\\n\",\n",
    "    \"                cur.execute(\\\"DELETE FROM _staging_snippets WHERE doc_id = %s AND searchquery = %s\\\",\\n\",\n",
    "    \"                            (row['doc_id'], row['searchquery']))\\n\",\n",
    "    \"            target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Process matching_columns snippets — iterate inline, write to staging\\n\",\n",
    "    \"            for s in insert_data._safe_eval(row['matching_columns_raw']):\\n\",\n",
    "    \"                result = expand_classify_with_retry(source_conn, row['doc_id'], s)\\n\",\n",
    "    \"                with target_conn.cursor() as cur:\\n\",\n",
    "    \"                    cur.execute(\\\"\\\"\\\"INSERT INTO _staging_snippets\\n\",\n",
    "    \"                        (doc_id, searchquery, snippet_type, snippet_text, clause_text,\\n\",\n",
    "    \"                         is_contract_clause, confidence, reasoning)\\n\",\n",
    "    \"                        VALUES (%s,%s,'mc',%s,%s,%s,%s,%s)\\\"\\\"\\\",\\n\",\n",
    "    \"                        (row['doc_id'], row['searchquery'], s,\\n\",\n",
    "    \"                         result['clause_text'], result['is_contract_clause'],\\n\",\n",
    "    \"                         result['classification_confidence'], result['classification_reasoning']))\\n\",\n",
    "    \"                target_conn.commit()\\n\",\n",
    "    \"                del result\\n\",\n",
    "    \"                time.sleep(0.1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Process matching_indents snippets\\n\",\n",
    "    \"            for s in insert_data._safe_eval(row['matching_indents_raw']):\\n\",\n",
    "    \"                result = expand_classify_with_retry(source_conn, row['doc_id'], s)\\n\",\n",
    "    \"                with target_conn.cursor() as cur:\\n\",\n",
    "    \"                    cur.execute(\\\"\\\"\\\"INSERT INTO _staging_snippets\\n\",\n",
    "    \"                        (doc_id, searchquery, snippet_type, snippet_text, clause_text,\\n\",\n",
    "    \"                         is_contract_clause, confidence, reasoning)\\n\",\n",
    "    \"                        VALUES (%s,%s,'mi',%s,%s,%s,%s,%s)\\\"\\\"\\\",\\n\",\n",
    "    \"                        (row['doc_id'], row['searchquery'], s,\\n\",\n",
    "    \"                         result['clause_text'], result['is_contract_clause'],\\n\",\n",
    "    \"                         result['classification_confidence'], result['classification_reasoning']))\\n\",\n",
    "    \"                target_conn.commit()\\n\",\n",
    "    \"                del result\\n\",\n",
    "    \"                time.sleep(0.1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Aggregate from staging via SQL — no Python lists\\n\",\n",
    "    \"            with target_conn.cursor() as cur:\\n\",\n",
    "    \"                cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                    SELECT\\n\",\n",
    "    \"                        array_agg(clause_text) FILTER (WHERE snippet_type='mc'),\\n\",\n",
    "    \"                        array_agg(clause_text) FILTER (WHERE snippet_type='mi'),\\n\",\n",
    "    \"                        array_agg(snippet_text) FILTER (WHERE snippet_type='mc' AND is_contract_clause),\\n\",\n",
    "    \"                        array_agg(snippet_text) FILTER (WHERE snippet_type='mi' AND is_contract_clause),\\n\",\n",
    "    \"                        array_agg(clause_text) FILTER (WHERE snippet_type='mc' AND is_contract_clause),\\n\",\n",
    "    \"                        array_agg(clause_text) FILTER (WHERE snippet_type='mi' AND is_contract_clause),\\n\",\n",
    "    \"                        ROUND(AVG(confidence) FILTER (WHERE is_contract_clause)::numeric, 3),\\n\",\n",
    "    \"                        (array_agg(reasoning) FILTER (WHERE is_contract_clause))[1],\\n\",\n",
    "    \"                        ROUND(AVG(confidence)::numeric, 3),\\n\",\n",
    "    \"                        (array_agg(reasoning))[1],\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE snippet_type='mc'),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE snippet_type='mi'),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE is_contract_clause),\\n\",\n",
    "    \"                        (array_agg(clause_text) FILTER (WHERE is_contract_clause))[1]\\n\",\n",
    "    \"                    FROM _staging_snippets\\n\",\n",
    "    \"                    WHERE doc_id = %s AND searchquery = %s\\n\",\n",
    "    \"                \\\"\\\"\\\", (row['doc_id'], row['searchquery']))\\n\",\n",
    "    \"                agg = cur.fetchone()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # agg indices:\\n\",\n",
    "    \"            # 0=expanded_columns, 1=expanded_indents,\\n\",\n",
    "    \"            # 2=mc_after, 3=mi_after,\\n\",\n",
    "    \"            # 4=expanded_columns_after, 5=expanded_indents_after,\\n\",\n",
    "    \"            # 6=avg_classified_conf, 7=first_classified_reasoning,\\n\",\n",
    "    \"            # 8=avg_all_conf, 9=first_all_reasoning,\\n\",\n",
    "    \"            # 10=num_mc, 11=num_mi, 12=num_classified,\\n\",\n",
    "    \"            # 13=first_classified_clause\\n\",\n",
    "    \"\\n\",\n",
    "    \"            avg_confidence = float(agg[6] if agg[6] is not None else agg[8] or 0)\\n\",\n",
    "    \"            first_reasoning = agg[7] or agg[9] or ''\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Extract discussion if any classified clauses exist\\n\",\n",
    "    \"            extracted_discussion = ''\\n\",\n",
    "    \"            sentiment = ''\\n\",\n",
    "    \"            sentiment_conf = 0.0\\n\",\n",
    "    \"            if agg[13]:  # first_classified_clause exists\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    d = extract_discussion_with_retry(source_conn, row['doc_id'], agg[13])\\n\",\n",
    "    \"                    extracted_discussion = d['discussion']\\n\",\n",
    "    \"                    sentiment = d['sentiment']\\n\",\n",
    "    \"                    sentiment_conf = d['sentiment_confidence']\\n\",\n",
    "    \"                    stats['total_discussions_extracted'] += 1\\n\",\n",
    "    \"                except Exception as e:\\n\",\n",
    "    \"                    print(f\\\"  Discussion error for doc_id={row['doc_id']}: {e}\\\")\\n\",\n",
    "    \"                time.sleep(0.1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Insert into target classified_index from aggregated staging data\\n\",\n",
    "    \"            with target_conn.cursor() as tgt_cur:\\n\",\n",
    "    \"                tgt_cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                    INSERT INTO classified_index(\\n\",\n",
    "    \"                        Doc_Id, Title, searchquery,\\n\",\n",
    "    \"                        matching_indents, matching_columns,\\n\",\n",
    "    \"                        matching_columns_after_classification,\\n\",\n",
    "    \"                        matching_indents_after_classification,\\n\",\n",
    "    \"                        expanded_columns, expanded_indents,\\n\",\n",
    "    \"                        expanded_columns_after_classification,\\n\",\n",
    "    \"                        expanded_indents_after_classification,\\n\",\n",
    "    \"                        extracted_discussion, sentiment,\\n\",\n",
    "    \"                        classification_confidence, classification_reasoning,\\n\",\n",
    "    \"                        sentiment_confidence\\n\",\n",
    "    \"                    ) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)\\n\",\n",
    "    \"                    ON CONFLICT (Doc_Id, searchquery) DO UPDATE SET\\n\",\n",
    "    \"                        Title = EXCLUDED.Title,\\n\",\n",
    "    \"                        matching_indents = EXCLUDED.matching_indents,\\n\",\n",
    "    \"                        matching_columns = EXCLUDED.matching_columns,\\n\",\n",
    "    \"                        matching_columns_after_classification = EXCLUDED.matching_columns_after_classification,\\n\",\n",
    "    \"                        matching_indents_after_classification = EXCLUDED.matching_indents_after_classification,\\n\",\n",
    "    \"                        expanded_columns = EXCLUDED.expanded_columns,\\n\",\n",
    "    \"                        expanded_indents = EXCLUDED.expanded_indents,\\n\",\n",
    "    \"                        expanded_columns_after_classification = EXCLUDED.expanded_columns_after_classification,\\n\",\n",
    "    \"                        expanded_indents_after_classification = EXCLUDED.expanded_indents_after_classification,\\n\",\n",
    "    \"                        extracted_discussion = EXCLUDED.extracted_discussion,\\n\",\n",
    "    \"                        sentiment = EXCLUDED.sentiment,\\n\",\n",
    "    \"                        classification_confidence = EXCLUDED.classification_confidence,\\n\",\n",
    "    \"                        classification_reasoning = EXCLUDED.classification_reasoning,\\n\",\n",
    "    \"                        sentiment_confidence = EXCLUDED.sentiment_confidence\\n\",\n",
    "    \"                \\\"\\\"\\\", (\\n\",\n",
    "    \"                    row['doc_id'], row['title'], row['searchquery'],\\n\",\n",
    "    \"                    row['matching_indents_raw'], row['matching_columns_raw'],\\n\",\n",
    "    \"                    str(agg[2] or []), str(agg[3] or []),\\n\",\n",
    "    \"                    str(agg[0] or []), str(agg[1] or []),\\n\",\n",
    "    \"                    str(agg[4] or []), str(agg[5] or []),\\n\",\n",
    "    \"                    extracted_discussion, sentiment,\\n\",\n",
    "    \"                    str(avg_confidence), first_reasoning,\\n\",\n",
    "    \"                    str(round(sentiment_conf, 3)),\\n\",\n",
    "    \"                ))\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Track stats\\n\",\n",
    "    \"            stats['total_expanded'] += (agg[10] or 0) + (agg[11] or 0)\\n\",\n",
    "    \"            stats['total_classified_as_clause'] += agg[12] or 0\\n\",\n",
    "    \"            stats['total_processed'] += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            print(f\\\"  ERROR processing doc_id={row['doc_id']} query={row['searchquery']}: {e}\\\")\\n\",\n",
    "    \"            stats['total_errors'] += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Commit and save stats after each batch\\n\",\n",
    "    \"    target_conn.commit()\\n\",\n",
    "    \"    save_stats()\\n\",\n",
    "    \"    print(f\\\"Batch {batch_num} complete \\\"\\n\",\n",
    "    \"          f\\\"({stats['total_processed']} total processed, \\\"\\n\",\n",
    "    \"          f\\\"{stats['total_discussions_extracted']} discussions, \\\"\\n\",\n",
    "    \"          f\\\"{stats['total_errors']} errors)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nProcessing complete. Final stats: {stats}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Cell 9: Verification\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Row counts in target\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index\\\")\\n\",\n",
    "    \"    target_ci_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM stored_results\\\")\\n\",\n",
    "    \"    target_sr_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM search_queries\\\")\\n\",\n",
    "    \"    target_sq_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index WHERE LENGTH(extracted_discussion) > 0\\\")\\n\",\n",
    "    \"    target_disc_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index WHERE classification_confidence IS NOT NULL AND classification_confidence != ''\\\")\\n\",\n",
    "    \"    target_conf_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM stored_results WHERE court_name IS NOT NULL AND court_name != ''\\\")\\n\",\n",
    "    \"    target_meta_count = cur.fetchone()[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Row counts in source\\n\",\n",
    "    \"with source_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM classified_index\\\")\\n\",\n",
    "    \"    source_ci_count = cur.fetchone()[0]\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*) FROM stored_results\\\")\\n\",\n",
    "    \"    source_sr_count = cur.fetchone()[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=== Row Count Comparison ===\\\")\\n\",\n",
    "    \"print(f\\\"  classified_index:  source={source_ci_count}  target={target_ci_count}\\\")\\n\",\n",
    "    \"print(f\\\"  stored_results:    source={source_sr_count}  target={target_sr_count}\\\")\\n\",\n",
    "    \"print(f\\\"  search_queries:    target={target_sq_count}\\\")\\n\",\n",
    "    \"print(f\\\"  with discussion:   target={target_disc_count}\\\")\\n\",\n",
    "    \"print(f\\\"  with confidence:   target={target_conf_count}\\\")\\n\",\n",
    "    \"print(f\\\"  with court meta:   target={target_meta_count}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Sentiment distribution with confidence\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        SELECT sentiment, COUNT(*),\\n\",\n",
    "    \"               AVG(CASE WHEN sentiment_confidence != '' THEN CAST(sentiment_confidence AS FLOAT) ELSE NULL END)\\n\",\n",
    "    \"        FROM classified_index\\n\",\n",
    "    \"        WHERE LENGTH(extracted_discussion) > 0\\n\",\n",
    "    \"        GROUP BY sentiment\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    sentiment_dist = cur.fetchall()\\n\",\n",
    "    \"\\n\",\n",
    "    \"if sentiment_dist:\\n\",\n",
    "    \"    print(\\\"\\\\n=== Sentiment Distribution (with avg confidence) ===\\\")\\n\",\n",
    "    \"    for sentiment, count, avg_conf in sentiment_dist:\\n\",\n",
    "    \"        avg_str = f\\\"{avg_conf:.2f}\\\" if avg_conf else \\\"N/A\\\"\\n\",\n",
    "    \"        print(f\\\"  {sentiment or '(empty)'}: {count} (avg confidence: {avg_str})\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Classification confidence distribution\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        SELECT \\n\",\n",
    "    \"            CASE \\n\",\n",
    "    \"                WHEN CAST(classification_confidence AS FLOAT) >= 0.8 THEN 'high (>=0.8)'\\n\",\n",
    "    \"                WHEN CAST(classification_confidence AS FLOAT) >= 0.5 THEN 'medium (0.5-0.8)'\\n\",\n",
    "    \"                ELSE 'low (<0.5)'\\n\",\n",
    "    \"            END as conf_bucket,\\n\",\n",
    "    \"            COUNT(*)\\n\",\n",
    "    \"        FROM classified_index\\n\",\n",
    "    \"        WHERE classification_confidence IS NOT NULL AND classification_confidence != ''\\n\",\n",
    "    \"        GROUP BY conf_bucket\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    conf_dist = cur.fetchall()\\n\",\n",
    "    \"\\n\",\n",
    "    \"if conf_dist:\\n\",\n",
    "    \"    print(\\\"\\\\n=== Classification Confidence Distribution ===\\\")\\n\",\n",
    "    \"    for bucket, count in conf_dist:\\n\",\n",
    "    \"        print(f\\\"  {bucket}: {count}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show sample rows with all new fields\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        SELECT ci.doc_id, ci.searchquery, ci.sentiment,\\n\",\n",
