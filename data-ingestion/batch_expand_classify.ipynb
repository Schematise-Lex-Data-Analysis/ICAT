    "   \"source\": [\n",
    "    \"# Cell 3: Test Run — Randomised Sample Across Queries\\n\",\n",
    "    \"# Combined pipeline: expand + classify + extract discussion, all via LLM.\\n\",\n",
    "    \"# All document text stays in PostgreSQL — only small context windows enter Python.\\n\",\n",
    "    \"# Snippet-level results go to a temp table; display is a SQL aggregation.\\n\",\n",
    "    \"# No intermediate Python variables for snippets, results, or discussions.\\n\",\n",
    "    \"\\n\",\n",
    "    \"import csv\\n\",\n",
    "    \"import gc\\n\",\n",
    "    \"import resource\\n\",\n",
    "    \"import importlib\\n\",\n",
    "    \"importlib.reload(pipelineoperation)\\n\",\n",
    "    \"from pipelineoperation import expand_and_classify_with_azure, extract_discussion_with_azure\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- Leak-detection diagnostics ---\\n\",\n",
    "    \"_last_rss = [0]  # mutable container so closure can update it\\n\",\n",
    "    \"\\n\",\n",
    "    \"def mem_report(label=\\\"\\\"):\\n\",\n",
    "    \"    \\\"\\\"\\\"Print current RSS + peak RSS + delta since last call.\\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        with open('/proc/self/status') as f:\\n\",\n",
    "    \"            for line in f:\\n\",\n",
    "    \"                if line.startswith('VmRSS:'):\\n\",\n",
    "    \"                    current_rss_mb = int(line.split()[1]) / 1024  # kB -> MB\\n\",\n",
    "    \"                    break\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                current_rss_mb = 0\\n\",\n",
    "    \"    except OSError:\\n\",\n",
    "    \"        current_rss_mb = 0\\n\",\n",
    "    \"    peak_rss_mb = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss / 1024\\n\",\n",
    "    \"    delta = current_rss_mb - _last_rss[0] if _last_rss[0] > 0 else 0\\n\",\n",
    "    \"    sign = \\\"+\\\" if delta >= 0 else \\\"\\\"\\n\",\n",
    "    \"    print(f\\\"[MEM {label}] current: {current_rss_mb:.0f} MB  peak: {peak_rss_mb:.0f} MB  delta: {sign}{delta:.0f} MB\\\")\\n\",\n",
    "    \"    _last_rss[0] = current_rss_mb\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Clear any aborted transaction state on both connections\\n\",\n",
    "    \"source_conn.rollback()\\n\",\n",
    "    \"target_conn.rollback()\\n\",\n",
    "    \"\\n\",\n",
    "    \"mem_report(\\\"cell 3 start\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Materialize the randomised sample into a temp table on source — one query, no Python lists\\n\",\n",
    "    \"with source_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"DROP TABLE IF EXISTS _test_sample\\\")\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        CREATE TEMP TABLE _test_sample AS\\n\",\n",
    "    \"        SELECT doc_id, title, searchquery, matching_indents, matching_columns,\\n\",\n",
    "    \"               ROW_NUMBER() OVER () - 1 AS row_idx\\n\",\n",
    "    \"        FROM (\\n\",\n",
    "    \"            SELECT *, ROW_NUMBER() OVER (PARTITION BY searchquery ORDER BY RANDOM()) AS rn\\n\",\n",
    "    \"            FROM classified_index\\n\",\n",
    "    \"            WHERE searchquery IN (\\n\",\n",
    "    \"                SELECT searchquery FROM (\\n\",\n",
    "    \"                    SELECT searchquery\\n\",\n",
    "    \"                    FROM classified_index\\n\",\n",
    "    \"                    WHERE LENGTH(matching_columns) > 2 OR LENGTH(matching_indents) > 2\\n\",\n",
    "    \"                    GROUP BY searchquery\\n\",\n",
    "    \"                    ORDER BY RANDOM() LIMIT 5\\n\",\n",
    "    \"                ) q\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"            AND (LENGTH(matching_columns) > 2 OR LENGTH(matching_indents) > 2)\\n\",\n",
    "    \"        ) ranked WHERE rn <= 4\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    source_conn.commit()\\n\",\n",
    "    \"    cur.execute(\\\"SELECT COUNT(*), array_agg(DISTINCT searchquery) FROM _test_sample\\\")\\n\",\n",
    "    \"    sample_count, sample_queries = cur.fetchone()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Randomly selected queries: {sample_queries}\\\")\\n\",\n",
    "    \"print(f\\\"Randomly sampled {sample_count} test rows\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Temp tables for intermediate results (on target_conn so they survive commits)\\n\",\n",
    "    \"with target_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"DROP TABLE IF EXISTS test_run_snippets\\\")\\n\",\n",
    "    \"    cur.execute(\\\"DROP TABLE IF EXISTS test_run_rows\\\")\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        CREATE TEMP TABLE test_run_snippets (\\n\",\n",
    "    \"            row_idx INT, doc_id TEXT, query TEXT, title TEXT,\\n\",\n",
    "    \"            snippet_type TEXT, snippet_text TEXT, clause_text TEXT,\\n\",\n",
    "    \"            is_contract_clause BOOLEAN, confidence FLOAT, reasoning TEXT\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"        CREATE TEMP TABLE test_run_rows (\\n\",\n",
    "    \"            row_idx INT, doc_id TEXT, query TEXT, title TEXT,\\n\",\n",
    "    \"            discussion TEXT, sentiment TEXT, sentiment_confidence FLOAT,\\n\",\n",
    "    \"            is_contract BOOLEAN\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    \\\"\\\"\\\")\\n\",\n",
    "    \"    target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Prepare TSV output file\\n\",\n",
    "    \"timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')\\n\",\n",
    "    \"csv_path = f\\\"test_run_{timestamp}.tsv\\\"\\n\",\n",
    "    \"FULL_COLUMNS = [\\n\",\n",
    "    \"    'Query', 'DocID', 'Title', 'Snippets_MC', 'Snippets_MI',\\n\",\n",
    "    \"    'Expanded_MC', 'Expanded_MI', 'Classified_MC', 'Classified_MI',\\n\",\n",
    "    \"    'Num_Snippets_MC', 'Num_Snippets_MI', 'Num_Classified_MC', 'Num_Classified_MI',\\n\",\n",
    "    \"    'Avg_Classification_Confidence', 'All_Confidences', 'All_Reasonings',\\n\",\n",
    "    \"    'Sentiment', 'Sentiment_Confidence', 'Discussion',\\n\",\n",
    "    \"    'Is_Contract', 'IndianKanoon_URL',\\n\",\n",
    "    \"]\\n\",\n",
    "    \"tsv_file = open(csv_path, 'w', newline='')\\n\",\n",
    "    \"tsv_writer = csv.DictWriter(tsv_file, fieldnames=FULL_COLUMNS, delimiter='\\\\t')\\n\",\n",
    "    \"tsv_writer.writeheader()\\n\",\n",
    "    \"tsv_file.flush()\\n\",\n",
    "    \"\\n\",\n",
    "    \"test_errors = []\\n\",\n",
    "    \"rows_written = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"mem_report(\\\"before row loop\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Stream rows from the temp table — no Python list\\n\",\n",
    "    \"with source_conn.cursor(name=\\\"test_sample_cursor\\\") as src_cur:\\n\",\n",
    "    \"    src_cur.itersize = 1\\n\",\n",
    "    \"    src_cur.execute(\\\"SELECT row_idx, doc_id, title, searchquery, matching_indents, matching_columns FROM _test_sample ORDER BY row_idx\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for row_idx, doc_id, title, query, mi_raw, mc_raw in src_cur:\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            mc_snippets = insert_data._safe_eval(mc_raw)\\n\",\n",
    "    \"            mi_snippets = insert_data._safe_eval(mi_raw)\\n\",\n",
    "    \"            print(f\\\"  [Row {row_idx+1}/{sample_count}] doc={doc_id} mc_count={len(mc_snippets)} mi_count={len(mi_snippets)}\\\")\\n\",\n",
    "    \"            mem_report(f\\\"row {row_idx+1} start\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Process MC snippets — parse and iterate inline, no stored list\\n\",\n",
    "    \"            for si, s in enumerate(mc_snippets):\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    result = expand_and_classify_with_azure(source_conn, doc_id, s)\\n\",\n",
    "    \"                except Exception as e:\\n\",\n",
    "    \"                    print(f\\\"  [Row {row_idx+1}] expand+classify error for MC snippet in doc {doc_id}: {e}\\\")\\n\",\n",
    "    \"                    result = {'clause_text': s, 'is_contract_clause': False,\\n\",\n",
    "    \"                              'classification_confidence': 0.0, 'classification_reasoning': f'Error: {e}'}\\n\",\n",
    "    \"                with target_conn.cursor() as cur:\\n\",\n",
    "    \"                    cur.execute(\\\"\\\"\\\"INSERT INTO test_run_snippets\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title, snippet_type, snippet_text,\\n\",\n",
    "    \"                         clause_text, is_contract_clause, confidence, reasoning)\\n\",\n",
    "    \"                        VALUES (%s,%s,%s,%s,'mc',%s,%s,%s,%s,%s)\\\"\\\"\\\",\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title, s,\\n\",\n",
    "    \"                         result['clause_text'], result['is_contract_clause'],\\n\",\n",
    "    \"                         result['classification_confidence'], result['classification_reasoning']))\\n\",\n",
    "    \"                target_conn.commit()\\n\",\n",
    "    \"                del result\\n\",\n",
    "    \"                gc.collect()\\n\",\n",
    "    \"                # Report every call for first 10, then every 5th\\n\",\n",
    "    \"                if si < 10 or (si + 1) % 5 == 0:\\n\",\n",
    "    \"                    mem_report(f\\\"row {row_idx+1} after mc[{si+1}/{len(mc_snippets)}]\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Process MI snippets — parse and iterate inline\\n\",\n",
    "    \"            for si, s in enumerate(mi_snippets):\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    result = expand_and_classify_with_azure(source_conn, doc_id, s)\\n\",\n",
    "    \"                except Exception as e:\\n\",\n",
    "    \"                    print(f\\\"  [Row {row_idx+1}] expand+classify error for MI snippet in doc {doc_id}: {e}\\\")\\n\",\n",
    "    \"                    result = {'clause_text': s, 'is_contract_clause': False,\\n\",\n",
    "    \"                              'classification_confidence': 0.0, 'classification_reasoning': f'Error: {e}'}\\n\",\n",
    "    \"                with target_conn.cursor() as cur:\\n\",\n",
    "    \"                    cur.execute(\\\"\\\"\\\"INSERT INTO test_run_snippets\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title, snippet_type, snippet_text,\\n\",\n",
    "    \"                         clause_text, is_contract_clause, confidence, reasoning)\\n\",\n",
    "    \"                        VALUES (%s,%s,%s,%s,'mi',%s,%s,%s,%s,%s)\\\"\\\"\\\",\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title, s,\\n\",\n",
    "    \"                         result['clause_text'], result['is_contract_clause'],\\n\",\n",
    "    \"                         result['classification_confidence'], result['classification_reasoning']))\\n\",\n",
    "    \"                target_conn.commit()\\n\",\n",
    "    \"                del result\\n\",\n",
    "    \"                gc.collect()\\n\",\n",
    "    \"                if si < 10 or (si + 1) % 5 == 0:\\n\",\n",
    "    \"                    mem_report(f\\\"row {row_idx+1} after mi[{si+1}/{len(mi_snippets)}]\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Discussion extraction — fetch first classified clause from DB,\\n\",\n",
    "    \"            # call LLM once via walrus operator, write result straight to DB\\n\",\n",
    "    \"            with target_conn.cursor() as cur:\\n\",\n",
    "    \"                cur.execute(\\\"\\\"\\\"SELECT clause_text FROM test_run_snippets\\n\",\n",
    "    \"                    WHERE row_idx = %s AND is_contract_clause = true LIMIT 1\\\"\\\"\\\", (row_idx,))\\n\",\n",
    "    \"                clause_row = cur.fetchone()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if clause_row:\\n\",\n",
    "    \"                mem_report(f\\\"row {row_idx+1} before discussion extraction\\\")\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    with target_conn.cursor() as cur:\\n\",\n",
    "    \"                        cur.execute(\\\"\\\"\\\"INSERT INTO test_run_rows\\n\",\n",
    "    \"                            (row_idx, doc_id, query, title, discussion, sentiment,\\n\",\n",
    "    \"                             sentiment_confidence, is_contract)\\n\",\n",
    "    \"                            VALUES (%s,%s,%s,%s,%s,%s,%s,true)\\\"\\\"\\\",\\n\",\n",
    "    \"                            (row_idx, doc_id, query, title,\\n\",\n",
    "    \"                             (d := extract_discussion_with_azure(source_conn, doc_id, clause_row[0]))['discussion'],\\n\",\n",
    "    \"                             d['sentiment'], d['sentiment_confidence']))\\n\",\n",
    "    \"                    mem_report(f\\\"row {row_idx+1} after discussion extraction\\\")\\n\",\n",
    "    \"                except Exception as e:\\n\",\n",
    "    \"                    print(f\\\"  [Row {row_idx+1}] discussion extraction error for doc {doc_id}: {e}\\\")\\n\",\n",
    "    \"                    with target_conn.cursor() as cur:\\n\",\n",
    "    \"                        cur.execute(\\\"\\\"\\\"INSERT INTO test_run_rows\\n\",\n",
    "    \"                            (row_idx, doc_id, query, title, discussion, sentiment,\\n\",\n",
    "    \"                             sentiment_confidence, is_contract)\\n\",\n",
    "    \"                            VALUES (%s,%s,%s,%s,'','',0.0,true)\\\"\\\"\\\",\\n\",\n",
    "    \"                            (row_idx, doc_id, query, title))\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                with target_conn.cursor() as cur:\\n\",\n",
    "    \"                    cur.execute(\\\"\\\"\\\"INSERT INTO test_run_rows\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title, discussion, sentiment,\\n\",\n",
    "    \"                         sentiment_confidence, is_contract)\\n\",\n",
    "    \"                        VALUES (%s,%s,%s,%s,'','',0.0,false)\\\"\\\"\\\",\\n\",\n",
    "    \"                        (row_idx, doc_id, query, title))\\n\",\n",
    "    \"            target_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Write TSV row by querying aggregates from temp tables\\n\",\n",
    "    \"            with target_conn.cursor() as cur:\\n\",\n",
    "    \"                cur.execute(\\\"\\\"\\\"\\n\",\n",
    "    \"                    SELECT\\n\",\n",
    "    \"                        array_agg(s.snippet_text) FILTER (WHERE s.snippet_type='mc'),\\n\",\n",
    "    \"                        array_agg(s.snippet_text) FILTER (WHERE s.snippet_type='mi'),\\n\",\n",
    "    \"                        array_agg(s.clause_text) FILTER (WHERE s.snippet_type='mc'),\\n\",\n",
    "    \"                        array_agg(s.clause_text) FILTER (WHERE s.snippet_type='mi'),\\n\",\n",
    "    \"                        array_agg(s.clause_text) FILTER (WHERE s.snippet_type='mc' AND s.is_contract_clause),\\n\",\n",
    "    \"                        array_agg(s.clause_text) FILTER (WHERE s.snippet_type='mi' AND s.is_contract_clause),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE s.snippet_type='mc'),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE s.snippet_type='mi'),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE s.snippet_type='mc' AND s.is_contract_clause),\\n\",\n",
    "    \"                        COUNT(*) FILTER (WHERE s.snippet_type='mi' AND s.is_contract_clause),\\n\",\n",
    "    \"                        ROUND(AVG(s.confidence) FILTER (WHERE s.is_contract_clause)::numeric, 4),\\n\",\n",
    "    \"                        array_agg(s.confidence),\\n\",\n",
    "    \"                        array_agg(s.reasoning),\\n\",\n",
    "    \"                        r.sentiment, ROUND(r.sentiment_confidence::numeric, 4),\\n\",\n",
    "    \"                        r.discussion, r.is_contract\\n\",\n",
    "    \"                    FROM test_run_rows r\\n\",\n",
    "    \"                    LEFT JOIN test_run_snippets s USING (row_idx)\\n\",\n",
    "    \"                    WHERE r.row_idx = %s\\n\",\n",
    "    \"                    GROUP BY r.row_idx, r.sentiment, r.sentiment_confidence,\\n\",\n",
    "    \"                             r.discussion, r.is_contract\\n\",\n",
    "    \"                \\\"\\\"\\\", (row_idx,))\\n\",\n",
    "    \"                agg = cur.fetchone()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            tsv_writer.writerow({\\n\",\n",
    "    \"                'Query': query, 'DocID': doc_id, 'Title': title or '',\\n\",\n",
    "    \"                'Snippets_MC': str(agg[0] or []), 'Snippets_MI': str(agg[1] or []),\\n\",\n",
    "    \"                'Expanded_MC': str(agg[2] or []), 'Expanded_MI': str(agg[3] or []),\\n\",\n",
    "    \"                'Classified_MC': str(agg[4] or []), 'Classified_MI': str(agg[5] or []),\\n\",\n",
    "    \"                'Num_Snippets_MC': agg[6], 'Num_Snippets_MI': agg[7],\\n\",\n",
    "    \"                'Num_Classified_MC': agg[8], 'Num_Classified_MI': agg[9],\\n\",\n",
    "    \"                'Avg_Classification_Confidence': float(agg[10] or 0),\\n\",\n",
    "    \"                'All_Confidences': str(agg[11] or []),\\n\",\n",
    "    \"                'All_Reasonings': str(agg[12] or []),\\n\",\n",
    "    \"                'Sentiment': agg[13] or '', 'Sentiment_Confidence': float(agg[14] or 0),\\n\",\n",
    "    \"                'Discussion': agg[15] or '',\\n\",\n",
    "    \"                'Is_Contract': 'Yes' if agg[16] else 'No',\\n\",\n",
    "    \"                'IndianKanoon_URL': f'https://indiankanoon.org/doc/{doc_id}/',\\n\",\n",
    "    \"            })\\n\",\n",
    "    \"            tsv_file.flush()\\n\",\n",
    "    \"            rows_written += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            print(f\\\"  Row {row_idx+1}/{sample_count}: doc={doc_id} mc={agg[6]} mi={agg[7]} \\\"\\n\",\n",
    "    \"                  f\\\"cls_mc={agg[8]} cls_mi={agg[9]} contract={'Yes' if agg[16] else 'No'}\\\")\\n\",\n",
    "    \"            mem_report(f\\\"row {row_idx+1} DONE\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        except Exception as e:\\n\",\n",
    "    \"            print(f\\\"  [Row {row_idx+1}] SKIPPED doc {doc_id} (query={query}): {e}\\\")\\n\",\n",
    "    \"            test_errors.append({'doc_id': doc_id, 'query': query, 'error': str(e)})\\n\",\n",
    "    \"\\n\",\n",
    "    \"        gc.collect()\\n\",\n",
    "    \"\\n\",\n",
    "    \"tsv_file.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Clean up source temp table\\n\",\n",
    "    \"with source_conn.cursor() as cur:\\n\",\n",
    "    \"    cur.execute(\\\"DROP TABLE IF EXISTS _test_sample\\\")\\n\",\n",
    "    \"    source_conn.commit()\\n\",\n",
    "    \"\\n\",\n",
    "    \"mem_report(\\\"end of cell 3\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display summary table via SQL aggregation\\n\",\n",
    "    \"df_display = pd.read_sql(\\\"\\\"\\\"\\n\",\n",
    "    \"    SELECT r.query AS \\\"Query\\\", r.doc_id AS \\\"DocID\\\", LEFT(r.title, 50) AS \\\"Title\\\",\\n\",\n",
    "    \"           COUNT(*) FILTER (WHERE s.snippet_type='mc') AS \\\"MC\\\",\\n\",\n",
    "    \"           COUNT(*) FILTER (WHERE s.snippet_type='mi') AS \\\"MI\\\",\\n\",\n",
    "    \"           COUNT(*) FILTER (WHERE s.snippet_type='mc' AND s.is_contract_clause) AS \\\"Cls MC\\\",\\n\",\n",
    "    \"           COUNT(*) FILTER (WHERE s.snippet_type='mi' AND s.is_contract_clause) AS \\\"Cls MI\\\",\\n\",\n",
    "    \"           ROUND(AVG(s.confidence) FILTER (WHERE s.is_contract_clause)::numeric, 2) AS \\\"Cls Conf\\\",\\n\",\n",
    "    \"           r.sentiment AS \\\"Sentiment\\\",\\n\",\n",
    "    \"           ROUND(r.sentiment_confidence::numeric, 2) AS \\\"Sent Conf\\\",\\n\",\n",
    "    \"           LEFT(r.discussion, 200) AS \\\"Discussion\\\",\\n\",\n",
    "    \"           CASE WHEN r.is_contract THEN 'Yes' ELSE 'No' END AS \\\"Contract?\\\"\\n\",\n",
    "    \"    FROM test_run_rows r\\n\",\n",
    "    \"    LEFT JOIN test_run_snippets s USING (row_idx)\\n\",\n",
    "    \"    GROUP BY r.row_idx, r.query, r.doc_id, r.title,\\n\",\n",
    "    \"             r.sentiment, r.sentiment_confidence, r.discussion, r.is_contract\\n\",\n",
    "    \"    ORDER BY r.row_idx\\n\",\n",
    "    \"\\\"\\\"\\\", target_conn)\\n\",\n",
    "    \"display(df_display)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if test_errors:\\n\",\n",
    "    \"    print(f\\\"\\\\n** {len(test_errors)} row(s) failed: **\\\")\\n\",\n",
    "    \"    for err in test_errors:\\n\",\n",
    "    \"        print(f\\\"  DocID={err['doc_id']}  query={err['query']}  error={err['error']}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nFull details exported to: {csv_path}\\\")\\n\",\n",
    "    \"print(f\\\"  {rows_written} rows ({len(test_errors)} errors), {len(FULL_COLUMNS)} columns\\\")\\n\",\n",
    "    \"print(\\\"\\\\n** Review the table above. Confidence scores should now appear. **\\\")\\n\",\n",
    "    \"print(\\\"** Do not proceed to full processing until satisfied. **\\\")\"\n",
    "   ]\n",
    "  },\n",
